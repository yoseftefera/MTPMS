# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME="Procurement Management Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=pmp_development
DB_USERNAME=pmp_user
DB_PASSWORD=pmp_secret
DB_ROOT_PASSWORD=rootsecret

# ─────────────────────────────────────────────────────────────────────────────
# Cache & Session
# ─────────────────────────────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=pmp_

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─────────────────────────────────────────────────────────────────────────────
# Queue
# ─────────────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=redissecret
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ─────────────────────────────────────────────────────────────────────────────
# JWT Authentication (tymon/jwt-auth)
# ─────────────────────────────────────────────────────────────────────────────
# Minimum 64 characters — generate with: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=30

# ─────────────────────────────────────────────────────────────────────────────
# Mail
# ─────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@platform.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────────
# Broadcasting / WebSockets (Soketi — Pusher-compatible)
# ─────────────────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=pmp-app-id
PUSHER_APP_KEY=pmp-app-key
PUSHER_APP_SECRET=pmp-app-secret
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─────────────────────────────────────────────────────────────────────────────
# File Storage
# ─────────────────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# S3-compatible storage (set FILESYSTEM_DISK=s3 in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=pmp-files
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────────────────────────────────────────
# Multi-Tenancy
# ─────────────────────────────────────────────────────────────────────────────
# TTL in seconds for tenant resolution cache
TENANT_CACHE_TTL=60

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=60
RATE_LIMIT_API=300

# ─────────────────────────────────────────────────────────────────────────────
# Account Security
# ─────────────────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
PASSWORD_RESET_EXPIRY=60

# ─────────────────────────────────────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────────────────────────────────────
NOTIFICATION_QUEUE=notifications
NOTIFICATION_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────────────────
# Reports
# ─────────────────────────────────────────────────────────────────────────────
REPORT_CACHE_TTL=300
REPORT_SYNC_MAX_ROWS=10000

# ─────────────────────────────────────────────────────────────────────────────
# Telescope (local debugging only — disable in production)
# ─────────────────────────────────────────────────────────────────────────────
TELESCOPE_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# API Documentation (L5-Swagger / OpenAPI 3.0)
# ─────────────────────────────────────────────────────────────────────────────
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_USE_ABSOLUTE_PATH=true
L5_FORMAT_TO_USE_FOR_DOCS=json
L5_SWAGGER_UI_DOC_EXPANSION=none
L5_SWAGGER_UI_FILTERS=true
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=false
